---
import '../styles/components/post-card.scss';

interface Props {
	title: string;
	description: string;
	date: string;
	href: string;
	cover?: string;
	index?: number;
}

const { title, description, date, href, cover, index = 0 } = Astro.props;
// Rotate through accent tints for the placeholder / overlay when there is no cover
const tints = ['var(--accent-soft)', 'rgba(124, 92, 255, 0.14)', 'rgba(255, 138, 61, 0.14)'];
const tint = tints[index % tints.length];
---

<article class="post-card">
	<a class="post-card__link" href={href}>
		<div class="post-card__media" style={`--tint:${tint}`}>
			{cover ? (
				<img src={cover} alt={title} loading="lazy" />
			) : (
				<span class="post-card__placeholder">{title.charAt(0)}</span>
			)}
		</div>
		<div class="post-card__body">
			<h3 class="post-card__title">{title}</h3>
			<p class="post-card__desc">{description}</p>
			<p class="post-card__meta">{date}</p>
		</div>
	</a>
</article>
