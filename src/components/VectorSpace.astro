---
import '../styles/components/vector-space.scss';
import type { Locale } from '../i18n/utils';

interface Props {
	locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<div class="vector-space" id="vector-space" data-locale={locale}></div>

<script>
import * as THREE from 'three';
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

const container = document.getElementById('vector-space');
if (container) {
	const width = container.clientWidth;
	const height = container.clientHeight;

	// Locale-aware link prefix for topic posts
	const locale = container.dataset.locale === 'es' ? 'es' : 'en';
	const prefix = locale === 'es' ? '/es' : '';

	// Scene
	const scene = new THREE.Scene();

	// Camera
	const camera = new THREE.PerspectiveCamera(50, width / height, 0.1, 100);
	camera.position.set(4, 3, 5);

	// Renderer
	const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
	renderer.setSize(width, height);
	renderer.setPixelRatio(window.devicePixelRatio);
	container.appendChild(renderer.domElement);

	// Controls
	const controls = new OrbitControls(camera, renderer.domElement);
	controls.enableDamping = true;
	controls.dampingFactor = 0.05;
	controls.enableZoom = false;
	controls.enablePan = false;
	controls.autoRotate = true;
	controls.autoRotateSpeed = 1.5;

	// Theme colors
	function getColors() {
		const s = getComputedStyle(document.documentElement);
		return {
			fg: s.getPropertyValue('--fg').trim() || '#1a1a1a',
			accent: s.getPropertyValue('--accent').trim() || '#1566d6',
			bg: s.getPropertyValue('--bg').trim() || '#f5f0e8',
			border: s.getPropertyValue('--border-color').trim() || '#1a1a1a',
		};
	}

	let colors = getColors();

	// Axes (dashed lines)
	function createAxis(dir: THREE.Vector3, length: number) {
		const points = [new THREE.Vector3(0, 0, 0), dir.clone().multiplyScalar(length)];
		const geo = new THREE.BufferGeometry().setFromPoints(points);
		const mat = new THREE.LineDashedMaterial({
			color: colors.border,
			dashSize: 0.15,
			gapSize: 0.1,
			opacity: 0.25,
			transparent: true,
		});
		const line = new THREE.Line(geo, mat);
		line.computeLineDistances();
		return line;
	}

	const axisGroup = new THREE.Group();
	axisGroup.add(createAxis(new THREE.Vector3(1, 0, 0), 3.5));
	axisGroup.add(createAxis(new THREE.Vector3(0, 1, 0), 3.5));
	axisGroup.add(createAxis(new THREE.Vector3(0, 0, 1), 3.5));
	scene.add(axisGroup);

	// Clusters data (slug links each topic to an explanatory post)
	const clustersData = [
		{ label: 'LLMs', slug: 'llms', cx: -1.5, cy: 0.8, cz: 0.6, n: 8 },
		{ label: 'RAG', slug: 'rag', cx: 1.2, cy: -0.7, cz: -0.5, n: 7 },
		{ label: 'Agents', slug: 'agents', cx: 0.3, cy: 1.5, cz: -1.2, n: 6 },
		{ label: 'Embeddings', slug: 'embeddings', cx: -0.8, cy: -1.3, cz: -1.0, n: 8 },
		{ label: 'Transformers', slug: 'transformers', cx: 1.6, cy: 1.0, cz: 1.2, n: 7 },
		{ label: 'Vectors', slug: 'vectors', cx: -1.3, cy: -0.5, cz: 1.5, n: 6 },
	];

	const pointMeshes: THREE.Mesh[] = [];
	const lineMeshes: THREE.Line[] = [];
	const labelSprites: THREE.Sprite[] = [];

	// Create text texture for labels
	function createLabelTexture(text: string, fgColor: string, bgColor: string, accentColor: string, borderColor: string) {
		const canvas = document.createElement('canvas');
		const ctx = canvas.getContext('2d')!;
		const fontSize = 48;
		ctx.font = `bold ${fontSize}px "Space Mono", monospace`;
		const tw = ctx.measureText(text).width;
		const pad = 20;
		const w = tw + pad * 2;
		const h = fontSize + pad * 2;
		canvas.width = w + 8;
		canvas.height = h + 8;

		ctx.clearRect(0, 0, canvas.width, canvas.height);

		// Offset shadow
		ctx.fillStyle = accentColor;
		ctx.fillRect(6, 6, w, h);

		// Background
		ctx.fillStyle = bgColor;
		ctx.fillRect(0, 0, w, h);

		// Border
		ctx.strokeStyle = borderColor;
		ctx.lineWidth = 4;
		ctx.strokeRect(0, 0, w, h);

		// Text
		ctx.fillStyle = fgColor;
		ctx.font = `bold ${fontSize}px "Space Mono", monospace`;
		ctx.textAlign = 'center';
		ctx.textBaseline = 'middle';
		ctx.fillText(text, w / 2, h / 2 + 2);

		return canvas;
	}

	function buildScene() {
		colors = getColors();
		const accentHex = new THREE.Color(colors.accent);

		// Clear old
		pointMeshes.forEach(m => scene.remove(m));
		lineMeshes.forEach(m => scene.remove(m));
		labelSprites.forEach(m => scene.remove(m));
		pointMeshes.length = 0;
		lineMeshes.length = 0;
		labelSprites.length = 0;

		// Remove old axes and recreate
		scene.remove(axisGroup);
		axisGroup.clear();
		axisGroup.add(createAxis(new THREE.Vector3(1, 0, 0), 3.5));
		axisGroup.add(createAxis(new THREE.Vector3(0, 1, 0), 3.5));
		axisGroup.add(createAxis(new THREE.Vector3(0, 0, 1), 3.5));
		scene.add(axisGroup);

		clustersData.forEach(function(c) {
			const center = new THREE.Vector3(c.cx, c.cy, c.cz);

			// Scatter points
			for (let i = 0; i < c.n; i++) {
				const px = c.cx + (Math.random() - 0.5) * 0.8;
				const py = c.cy + (Math.random() - 0.5) * 0.8;
				const pz = c.cz + (Math.random() - 0.5) * 0.8;
				const pos = new THREE.Vector3(px, py, pz);

				// Square point (box)
				const geo = new THREE.BoxGeometry(0.1, 0.1, 0.1);
				const mat = new THREE.MeshBasicMaterial({ color: accentHex });
				const mesh = new THREE.Mesh(geo, mat);
				mesh.position.copy(pos);
				scene.add(mesh);
				pointMeshes.push(mesh);

				// Edge wireframe
				const edges = new THREE.EdgesGeometry(geo);
				const edgeMat = new THREE.LineBasicMaterial({ color: colors.border });
				const wireframe = new THREE.LineSegments(edges, edgeMat);
				wireframe.position.copy(pos);
				scene.add(wireframe);
				lineMeshes.push(wireframe as unknown as THREE.Line);

				// Line to center
				const lineGeo = new THREE.BufferGeometry().setFromPoints([pos, center]);
				const lineMat = new THREE.LineBasicMaterial({
					color: accentHex,
					opacity: 0.2,
					transparent: true,
				});
				const line = new THREE.Line(lineGeo, lineMat);
				scene.add(line);
				lineMeshes.push(line);
			}

			// Label sprite
			const labelCanvas = createLabelTexture(c.label, colors.fg, colors.bg, colors.accent, colors.border);
			const texture = new THREE.CanvasTexture(labelCanvas);
			texture.minFilter = THREE.LinearFilter;
			const spriteMat = new THREE.SpriteMaterial({ map: texture, transparent: true });
			const sprite = new THREE.Sprite(spriteMat);
			sprite.position.copy(center);
			const aspect = labelCanvas.width / labelCanvas.height;
			const spriteScale = 0.7;
			sprite.scale.set(spriteScale * aspect, spriteScale, 1);
			sprite.userData.slug = c.slug;
			scene.add(sprite);
			labelSprites.push(sprite);
		});
	}

	buildScene();

	// Watch for theme changes
	const observer = new MutationObserver(function() {
		buildScene();
	});
	observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

	// Clickable labels: raycast against the topic sprites
	const raycaster = new THREE.Raycaster();
	const pointer = new THREE.Vector2();
	const downPos = new THREE.Vector2();

	function spriteAtEvent(event: PointerEvent | MouseEvent) {
		const rect = renderer.domElement.getBoundingClientRect();
		pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
		pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
		raycaster.setFromCamera(pointer, camera);
		const hits = raycaster.intersectObjects(labelSprites);
		return hits.length > 0 ? (hits[0].object as THREE.Sprite) : null;
	}

	renderer.domElement.addEventListener('pointermove', function(event) {
		renderer.domElement.style.cursor = spriteAtEvent(event) ? 'pointer' : 'grab';
	});

	// Track press position so a drag-to-rotate doesn't trigger navigation
	renderer.domElement.addEventListener('pointerdown', function(event) {
		downPos.set(event.clientX, event.clientY);
	});

	renderer.domElement.addEventListener('pointerup', function(event) {
		const moved = Math.hypot(event.clientX - downPos.x, event.clientY - downPos.y);
		if (moved > 6) return;
		const sprite = spriteAtEvent(event);
		if (sprite && sprite.userData.slug) {
			window.location.href = `${prefix}/posts/${sprite.userData.slug}/`;
		}
	});

	// Animate
	function animate() {
		requestAnimationFrame(animate);
		controls.update();
		renderer.render(scene, camera);
	}
	animate();

	// Resize
	window.addEventListener('resize', function() {
		const w = container.clientWidth;
		const h = container.clientHeight;
		camera.aspect = w / h;
		camera.updateProjectionMatrix();
		renderer.setSize(w, h);
	});
}
</script>
