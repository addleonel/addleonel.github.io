---
import BaseLayout from '../layouts/BaseLayout.astro';
import Projects from '../components/Projects.astro';
import { t } from '../i18n/utils';

const tr = t('en');
---

<BaseLayout
	title="Projects"
	description="Projects by Leunel Aquino — AI agents, sales analytics with LLMs, ANPR computer vision and web platforms."
>
	<main class="container">
		<div class="content-wrapper">
			<h2 class="page-title">{tr.projects.title}</h2>
			<p class="projects-intro">{tr.projects.intro}</p>
			<Projects locale="en" showHeading={false} />
		</div>
	</main>
</BaseLayout>
