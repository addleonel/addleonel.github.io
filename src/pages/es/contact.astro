---

<BaseLayout
	title="Contacto"
	description="Ponte en contacto con Leunel Aquino — encuéntrame en GitHub, LinkedIn, YouTube e Instagram."
>
	<div class="contact-ticker">
		<div class="contact-ticker__track">
			{ticker.map((word) => <span class="contact-ticker__item">{word} &bull;</span>)}
		</div>
	</div>
	<main class="container">
		<header class="contact-head">
			<h1 class="contact-title">{tr.contact.title}</h1>
			<!-- <p class="contact-subtitle">{tr.contact.subtitle}</p> -->
		</header>

		<div class="contact-layout">
			<aside class="contact-aside">
				<h2 class="contact-aside__title">{tr.contact.socialTitle}</h2>
				<p class="contact-aside__text">{tr.contact.description}</p>
				<ul class="contact-links">
					{socials.map((s) => (
						<li>
							<a class="contact-link" href={s.href} target="_blank" rel="noopener noreferrer">
								<span class="contact-link__icon">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox={s.viewBox}><path fill="currentColor" d={s.path} /></svg>
								</span>
								<span class="contact-link__meta">
									<span class="contact-link__name">{s.name}</span>
									<span class="contact-link__handle">{s.label}</span>
								</span>
								<span class="contact-link__arrow" aria-hidden="true">&rarr;</span>
							</a>
						</li>
					))}
				</ul>
			</aside>

			<section class="contact-card">
				<h2 class="contact-card__title">{tr.contact.formTitle}</h2>
				<form id="contact-form" class="contact-form" data-email={email}>
					<div class="form-row">
						<label class="form-field">
							<span>{tr.contact.name}</span>
							<input type="text" name="name" required autocomplete="name" placeholder="Juan Pérez" />
						</label>
						<label class="form-field">
							<span>{tr.contact.email}</span>
							<input type="email" name="email" required autocomplete="email" placeholder="juan@correo.com" />
						</label>
					</div>
					<label class="form-field">
						<span>{tr.contact.message}</span>
						<textarea name="message" rows="5" required placeholder="Hola Leunel, …"></textarea>
					</label>
					<button type="submit" class="form-submit"
						data-label={tr.contact.send}
						data-sending={tr.contact.sending}
					>{tr.contact.send}</button>
					<p class="form-status" role="status"
						data-success={tr.contact.success}
						data-error={tr.contact.error}
					></p>
				</form>
			</section>
		</div>
	</main>
</BaseLayout>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	if (form) {
		const email = form.dataset.email;
		const button = form.querySelector('.form-submit') as HTMLButtonElement;
		const status = form.querySelector('.form-status') as HTMLParagraphElement;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			status.textContent = '';
			status.classList.remove('is-success', 'is-error');
			button.disabled = true;
			button.textContent = button.dataset.sending ?? 'Enviando…';

			try {
				const res = await fetch(`https://formsubmit.co/ajax/${email}`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(Object.fromEntries(new FormData(form))),
				});
				const data = await res.json();
				if (res.ok && data.success) {
					status.textContent = status.dataset.success ?? '';
					status.classList.add('is-success');
					form.reset();
				} else {
					throw new Error('request failed');
				}
			} catch {
				status.textContent = status.dataset.error ?? '';
				status.classList.add('is-error');
			} finally {
				button.disabled = false;
				button.textContent = button.dataset.label ?? '';
			}
		});
	}
</script>
