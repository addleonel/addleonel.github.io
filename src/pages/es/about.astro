---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Resume from '../../components/Resume.astro';
import { t } from '../../i18n/utils';

const tr = t('es');
---

<BaseLayout
	title="Acerca de mi"
	description="Acerca de Leunel Aquino Davila — desarrollador de software y estudiante de Ingeniería Industrial especializado en Ciencia de Datos, LLMs, RAG y agentes inteligentes. CV, habilidades y proyectos."
>
	<main class="container">
		<div class="content-wrapper">
			<h2 class="page-title">{tr.about.title}</h2>
			<Resume locale="es" />
		</div>
	</main>
</BaseLayout>
