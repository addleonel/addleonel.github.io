---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostPreview from '../components/PostPreview.astro';
import { t } from '../i18n/utils';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../utils/posts';

const tr = t('en');
const posts = sortPostsByDate(await getCollection('posts', ({ data }) => data.locale === 'en'));
---

<BaseLayout
	title="All publications"
	description="Articles and notes by Leunel Aquino on LLMs, RAG, agents, embeddings, transformers and software development."
>
	<main class="container">
		<div class="content-wrapper">
			<h2 class="page-title">{tr.posts.title}</h2>
			{posts.map((post) => (
				<PostPreview
					title={post.data.title}
					content={post.data.description}
					date={`${tr.posts.postedOn} ${post.data.date}`}
					href={`/posts/${post.data.slug}`}
				/>
			))}
		</div>
	</main>
</BaseLayout>
