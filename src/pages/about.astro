---
import BaseLayout from '../layouts/BaseLayout.astro';
import Resume from '../components/Resume.astro';
import { t } from '../i18n/utils';

const tr = t('en');
---

<BaseLayout
	title="About me"
	description="About Leunel Aquino Davila — software developer and Industrial Engineering student specializing in Data Science, LLMs, RAG and intelligent agents. CV, skills and projects."
>
	<main class="container">
		<div class="content-wrapper">
			<h2 class="page-title">{tr.about.title}</h2>
			<Resume locale="en" />
		</div>
	</main>
</BaseLayout>
