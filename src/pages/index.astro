---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostPreview from '../components/PostPreview.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import VectorSpace from '../components/VectorSpace.astro';
import '../styles/components/home.scss';
import { t } from '../i18n/utils';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../utils/posts';

const tr = t('en');
const posts = await getCollection('posts', ({ data }) => data.locale === 'en');
const latestPosts = sortPostsByDate(posts).slice(0, 3);
---

<BaseLayout
	title="Leunel's website"
	description="Leunel Aquino — software developer building LLM, RAG and agent systems. Read my notes on AI engineering and explore my projects."
>
	<section class="hero">
		<div class="container">
			<div class="content-wrapper">
				<VectorSpace locale="en" />
			</div>
		</div>
	</section>
	<main class="container">
		<div class="content-wrapper">
			<p class="last-posts">{tr.home.lastPosts}</p>
			{latestPosts.map((post) => (
				<PostPreview
					title={post.data.title}
					content={post.data.description}
					date={`${tr.posts.postedOn} ${post.data.date}`}
					href={`/posts/${post.data.slug}`}
				/>
			))}
		</div>
	</main>
	<section class="container more-post">
		<div class="content-wrapper">
			<a class="more-post__link" href="/posts/">{tr.home.allPosts} &rarr;</a>
		</div>
	</section>
	<section class="container">
		<FeaturedProjects locale="en" />
	</section>
</BaseLayout>
