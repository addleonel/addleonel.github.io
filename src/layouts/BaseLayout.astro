---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.scss';
import { getLocaleFromPath, switchLocalePath } from '../i18n/utils';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	keywords?: string;
	noindex?: boolean;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE_NAME = 'Leunel';
const DEFAULT_KEYWORDS = 'LLMs, RAG, Agents, embeddings, transformers, AI, machine learning, deep learning, software development';

const {
	title,
	description = "Leunel — Software developer focused on LLMs, RAG, Agents, embeddings, and AI engineering.",
	image = "/og_image.png",
	type = 'website',
	publishedTime,
	keywords = DEFAULT_KEYWORDS,
	noindex = false,
	jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const locale = getLocaleFromPath(Astro.url.pathname);
const ogLocale = locale === 'en' ? 'en_US' : 'es_ES';
const alternatePath = switchLocalePath(Astro.url.pathname);
const alternateURL = new URL(alternatePath, Astro.site);
const ogImageURL = new URL(image, Astro.site);

// Title: append the site name unless it's already part of the page title.
const fullTitle = title.includes(SITE_NAME) ? title : `${title} · ${SITE_NAME}`;

// Structured data — always describe the site and the author, plus any
// page-specific schema (e.g. a BlogPosting on post pages).
const websiteLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_NAME,
	url: Astro.site?.href,
	inLanguage: locale,
};
const personLd = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Leunel Aquino Davila',
	alternateName: 'Leunel',
	url: Astro.site?.href,
	image: ogImageURL.href,
	jobTitle: 'Software Developer',
	knowsAbout: ['LLMs', 'RAG', 'AI Agents', 'Embeddings', 'Transformers', 'Machine Learning', 'Software Development'],
	sameAs: [
		'https://github.com/addleonel',
		'https://www.linkedin.com/in/leunel',
		'https://www.instagram.com/addleonel/',
		'https://www.youtube.com/@addleonel',
	],
};
const structuredData = [websiteLd, personLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Leunel Aquino Davila" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#1566d6" />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

		<!-- Canonical & i18n alternates -->
		<link rel="canonical" href={canonicalURL.href} />
		<link rel="alternate" hreflang={locale === 'en' ? 'en' : 'es'} href={canonicalURL.href} />
		<link rel="alternate" hreflang={locale === 'en' ? 'es' : 'en'} href={alternateURL.href} />
		<link rel="alternate" hreflang="x-default" href={new URL(locale === 'en' ? Astro.url.pathname : alternatePath, Astro.site).href} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="manifest" href="/manifest.json" />

		<!-- Open Graph -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL.href} />
		<meta property="og:image:alt" content={title} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="Leunel" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:locale:alternate" content={locale === 'en' ? 'es_ES' : 'en_US'} />
		{type === 'article' && publishedTime && (
			<Fragment>
				<meta property="article:published_time" content={publishedTime} />
				<meta property="article:author" content="Leunel Aquino Davila" />
			</Fragment>
		)}

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL.href} />
		<meta name="twitter:image:alt" content={title} />

		<!-- Structured data (JSON-LD) -->
		{structuredData.map((data) => (
			<script type="application/ld+json" set:html={JSON.stringify(data)} />
		))}

		<!-- Theme script (prevent FOUC) -->
		<script is:inline>
			(function() {
				var stored = localStorage.getItem('theme') || 'system';
				var theme = stored;
				if (stored === 'system') {
					theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				}
				document.documentElement.setAttribute('data-theme', theme);
			})();
		</script>
	</head>
	<body>
		<Header currentPath={Astro.url.pathname} />
		<div class="site-main">
			<slot />
		</div>
		<Footer />
	</body>
</html>
